---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/$/, '')}/${path.replace(/^\//, '')}`;

const features = [
  {
    title: 'Self-hosted, always',
    body: 'Runs on your infrastructure in Docker or Kubernetes. No telemetry. No external data calls unless you ask for a metadata lookup.',
  },
  {
    title: 'Multi-library, multi-user',
    body: 'A single instance hosts independent libraries — shared household, personal collection, tech manuals — with per-library roles.',
  },
  {
    title: 'Print-first catalog',
    body: 'FRBR-style work/edition model tracks physical books, manga, comics, magazines, and technical documents without schema gymnastics.',
  },
  {
    title: 'Bring your own storage',
    body: 'For ebooks and PDFs, Librarium stores a path reference — your files stay where you put them.',
  },
  {
    title: 'Cross-platform',
    body: 'Go API, React web UI, and a native SwiftUI iOS app (TestFlight today, App Store soon).',
  },
  {
    title: 'Open source',
    body: 'Apache 2.0. Ship patches, file issues, or fork it — each client lives in its own repo and ships on its own cadence.',
  },
];

const webShots = [
  { src: asset('screenshots/web/dashboard.png'), alt: 'Librarium web dashboard' },
  { src: asset('screenshots/web/books_grid.png'), alt: 'Books grid view' },
  { src: asset('screenshots/web/books_list.png'), alt: 'Books list view' },
  { src: asset('screenshots/web/contrubitors.png'), alt: 'Contributors page' },
];

const iosShots = [
  { src: asset('screenshots/ios/library_catalogue.PNG'), alt: 'iOS library catalogue' },
  { src: asset('screenshots/ios/book_details.PNG'), alt: 'iOS book details' },
];

const repos = [
  { name: 'librarium-api', desc: 'Go backend · Postgres · River jobs', href: 'https://github.com/fireball1725/librarium-api' },
  { name: 'librarium-web', desc: 'React + TypeScript + Tailwind + Vite', href: 'https://github.com/fireball1725/librarium-web' },
  { name: 'librarium-ios', desc: 'SwiftUI · iOS 26+', href: 'https://github.com/fireball1725/librarium-ios' },
];
---

<Layout>
  <!-- Top nav -->
  <nav class="sticky top-0 z-20 border-b border-slate-800 bg-slate-950/80 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
      <a href={base} class="flex items-center gap-2.5">
        <img
          src={asset('logo.png')}
          alt=""
          width="32"
          height="32"
          class="h-8 w-8"
        />
        <span class="text-lg font-semibold tracking-tight text-white">Librarium</span>
      </a>
      <div class="flex items-center gap-6 text-sm">
        <a href="#screenshots" class="text-slate-300 transition hover:text-white">Screenshots</a>
        <a
          href="https://fireball1725.github.io/librarium-api/"
          class="text-slate-300 transition hover:text-white"
        >
          API docs
        </a>
        <a
          href="https://github.com/fireball1725/librarium"
          class="text-slate-300 transition hover:text-white"
        >
          GitHub
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <header class="relative overflow-hidden border-b border-slate-800">
    <div
      class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top,_var(--color-brand-500)/20,_transparent_60%)]"
    >
    </div>
    <div class="mx-auto max-w-6xl px-6 pt-20 pb-20 sm:pt-28 sm:pb-28">
      <img
        src={asset('logo.png')}
        alt="Librarium logo"
        width="96"
        height="96"
        class="mb-8 h-20 w-20 drop-shadow-[0_0_24px_rgba(79,70,229,0.5)] sm:h-24 sm:w-24"
      />
      <p class="text-sm font-semibold tracking-widest text-indigo-300 uppercase">
        Librarium
      </p>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-6xl">
        Catalog your shelves.<br />
        <span class="text-indigo-300">On your own server.</span>
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-slate-300 sm:text-xl">
        A self-hosted, privacy-focused tracker for physical books, manga, comics,
        and technical documents. One instance, many libraries, zero telemetry.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="https://github.com/fireball1725/librarium-api#deployment"
          class="inline-flex items-center gap-2 rounded-md bg-indigo-500 px-5 py-3 text-sm font-semibold text-white transition hover:bg-indigo-400"
        >
          Deploy it
        </a>
        <a
          href="#screenshots"
          class="inline-flex items-center gap-2 rounded-md border border-slate-700 bg-slate-900/60 px-5 py-3 text-sm font-semibold text-slate-100 transition hover:border-slate-500"
        >
          See it in action
        </a>
      </div>
    </div>
  </header>

  <!-- Features -->
  <section class="mx-auto max-w-6xl px-6 py-24">
    <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
      Built for collectors who run their own stack.
    </h2>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div class="rounded-lg border border-slate-800 bg-slate-900/50 p-6">
          <h3 class="text-lg font-semibold text-white">{f.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">{f.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Screenshots: web -->
  <section id="screenshots" class="border-t border-slate-800 bg-slate-900/30">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <p class="text-sm font-semibold tracking-widest text-indigo-300 uppercase">
        Web
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Browse, search, and curate from any browser.
      </h2>
      <div class="mt-12 grid gap-8 sm:grid-cols-2">
        {webShots.map((shot) => (
          <figure class="overflow-hidden rounded-lg border border-slate-800 bg-slate-950 shadow-xl">
            <img
              src={shot.src}
              alt={shot.alt}
              loading="lazy"
              class="h-auto w-full"
            />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Screenshots: iOS -->
  <section class="border-t border-slate-800">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <p class="text-sm font-semibold tracking-widest text-indigo-300 uppercase">
        iOS
      </p>
      <h2 class="mt-2 text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Scan barcodes at the bookstore. Catch up at home.
      </h2>
      <div class="mt-12 flex flex-wrap justify-center gap-8">
        {iosShots.map((shot) => (
          <figure class="w-full max-w-xs overflow-hidden rounded-[2rem] border border-slate-800 bg-slate-950 shadow-2xl">
            <img
              src={shot.src}
              alt={shot.alt}
              loading="lazy"
              class="h-auto w-full"
            />
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Repos -->
  <section class="border-t border-slate-800 bg-slate-900/30">
    <div class="mx-auto max-w-6xl px-6 py-24">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
        Three repos, one product.
      </h2>
      <p class="mt-3 max-w-2xl text-slate-300">
        API-first: every client consumes the same OpenAPI contract. Each piece
        ships independently on a <code class="rounded bg-slate-800 px-1.5 py-0.5 text-sm">YY.M.R</code> cadence.
      </p>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        {repos.map((r) => (
          <a
            href={r.href}
            class="group rounded-lg border border-slate-800 bg-slate-950 p-6 transition hover:border-indigo-500"
            data-repo={r.name}
          >
            <div class="flex items-center justify-between">
              <span class="font-mono text-sm text-white">{r.name}</span>
              <span
                class="text-slate-500 transition group-hover:translate-x-1 group-hover:text-indigo-300"
                aria-hidden="true"
              >
                →
              </span>
            </div>
            <p class="mt-2 text-sm text-slate-400">{r.desc}</p>
            <p class="mt-4 flex items-center gap-2 text-xs">
              <span class="font-mono text-slate-500">latest</span>
              <span
                class="rounded-full bg-slate-800/80 px-2 py-0.5 font-mono text-slate-300 opacity-0 transition-opacity data-[loaded]:opacity-100"
                data-version
                aria-live="polite"
              >—</span>
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <script>
    // Fetch the latest release tag for each repo card from the GitHub API.
    // Runs once on load. Unauthenticated requests are limited to 60/hr/IP,
    // which is plenty for a landing page. Repos without releases or with
    // API errors stay at the "—" placeholder and hide the badge.
    const cards = document.querySelectorAll<HTMLElement>('[data-repo]');
    for (const card of cards) {
      const repo = card.dataset.repo;
      const badge = card.querySelector<HTMLElement>('[data-version]');
      if (!repo || !badge) continue;
      fetch(`https://api.github.com/repos/fireball1725/${repo}/releases/latest`)
        .then((r) => (r.ok ? r.json() : null))
        .then((data) => {
          if (!data?.tag_name) return;
          badge.textContent = data.tag_name;
          badge.dataset.loaded = '';
        })
        .catch(() => { /* leave placeholder */ });
    }
  </script>

  <!-- Footer -->
  <footer class="border-t border-slate-800">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-6 px-6 py-10 sm:flex-row sm:items-center"
    >
      <p class="text-sm text-slate-400">
        © {new Date().getFullYear()} Librarium · Apache 2.0 licensed
      </p>
      <div class="flex gap-6 text-sm text-slate-400">
        <a href="https://github.com/fireball1725/librarium" class="hover:text-white">GitHub</a>
        <a href="https://github.com/fireball1725/librarium/issues" class="hover:text-white">Issues</a>
      </div>
    </div>
  </footer>
</Layout>
